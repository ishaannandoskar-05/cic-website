# ─── Frontend (Vite / Netlify) ───────────────────────────────────────────────
# Set this in Netlify → Site Settings → Environment Variables
# Point it to your Render backend URL (no trailing slash)
VITE_API_URL=https://cic-portal-backend.onrender.com

# ─── Backend (used by Docker Compose / Render) ───────────────────────────────
MONGO_URI=mongodb://localhost:27017/cic-website
JWT_SECRET=REPLACE_with_at_least_32_random_characters
JWT_EXPIRE=7d
ADMIN_SECRET_KEY=REPLACE_with_your_admin_secret_key
ALLOWED_ORIGINS=https://cic-club-nhitm.netlify.app

# ─── Compiler Sandbox ────────────────────────────────────────────────────────
SANDBOX_IMAGE=cic-sandbox:latest
EXEC_TIMEOUT_MS=10000

# ─── Optional integrations ───────────────────────────────────────────────────
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
GEMINI_API_KEY=
